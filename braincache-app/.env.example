# BrainCache environment configuration
# Copy this file to .env before running docker compose
# No API keys required. No accounts. No external services.

# Ollama model to use for AI inference
# Default: llama3.2 (~2GB, good balance of speed and quality)
# Alternatives: mistral, phi3, llama3.1, gemma2
# Full list: https://ollama.com/library
OLLAMA_MODEL=llama3.2
